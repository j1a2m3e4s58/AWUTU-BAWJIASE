rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    // Temporary launch mode while the app uses the hidden admin password instead of Firebase Auth.
    function launchAdminAccess() {
      return true;
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if launchAdminAccess();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if launchAdminAccess();
    }
  }
}
