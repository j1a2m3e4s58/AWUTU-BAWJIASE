{
  "name": "Comment",
  "type": "object",
  "properties": {
    "target_type": {
      "type": "string",
      "description": "The content type this comment belongs to."
    },
    "target_id": {
      "type": "string",
      "description": "The content id this comment belongs to."
    },
    "parent_id": {
      "type": "string",
      "description": "Optional parent comment id when this item is a reply."
    },
    "author_name": {
      "type": "string"
    },
    "author_email": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "moderation_status": {
      "type": "string",
      "enum": [
        "approved",
        "hidden",
        "spam",
        "reported"
      ],
      "default": "approved"
    },
    "is_admin": {
      "type": "boolean",
      "default": false
    },
    "published": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "target_type",
    "target_id",
    "author_name",
    "content"
  ]
}
